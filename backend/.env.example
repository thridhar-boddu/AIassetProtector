# =============================================================
# AssetGuardian Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!
# =============================================================

# PostgreSQL connection (Neon / Supabase / Railway / Render)
DATABASE_URL=jdbc:postgresql://<host>:5432/<dbname>?sslmode=require
DB_USERNAME=<your-db-user>
DB_PASSWORD=<your-db-password>

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Port (Render / Railway injects this automatically)
PORT=8080

# Deployed AI service URL
AI_SERVICE_URL=https://your-ai-service.onrender.com
