# =============================================================
# AssetGuardian Dashboard — Environment Variables Template
# Copy this file to .env.local (git-ignored) for local dev.
# In production, set these in Vercel / Netlify project settings.
# =============================================================

# Backend API base URL used by the Vite dev-server proxy.
# Leave blank in production builds (Vite builds use the deployed backend URL directly).
VITE_API_URL=http://localhost:8080

# Groq API key for the GeminiAssistant component.
# Users can also paste this in the UI — this env var pre-populates it.
VITE_GROQ_API_KEY=your_groq_api_key_here
